rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Server-side writes via Firebase Admin SDK bypass these rules.
    // Keep client writes blocked by default.
    match /links/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
    match /{document=**} {
      
    }
  }
}
